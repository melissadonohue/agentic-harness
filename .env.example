# =============================================================================
# Agentic Harness — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# See src/lib/env.ts for the schema that validates these at runtime.
# Never commit .env — only .env.example is checked in.
# =============================================================================

# --- Database (Postgres via Docker Compose) ---
# Default matches docker/docker-compose.yml settings.
DATABASE_URL="postgresql://harness:harness@localhost:5432/harness_dev"

# --- Application ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Auth (Clerk) — wired in Phase 6 ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""
# CLERK_WEBHOOK_SECRET=""

# --- Observability (Sentry) — wired in Phase 6 ---
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# --- Analytics & Feature Flags (PostHog) — wired in Phase 6 ---
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# --- Email (Mailpit for dev, Resend for prod) — wired via feature issue ---
# SMTP_HOST="localhost"
# SMTP_PORT="1025"

# --- Skip env validation (for CI builds without secrets) ---
# SKIP_ENV_VALIDATION="1"
